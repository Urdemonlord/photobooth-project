# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# CORS (comma-separated; kosong = allow origin yang sama + no-origin)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API security
# Jika diisi, semua endpoint /api/* wajib kirim header x-internal-api-key
INTERNAL_API_KEY=change-this-secret
API_RATE_LIMIT_PER_MIN=120

# Result upload constraints / cleanup
RESULT_MAX_BYTES=10485760
RESULTS_TTL_HOURS=24

# Printing
PRINT_ENABLED=false
PRINT_STRATEGY=lp
PRINT_COMMAND=lp
PRINT_PRINTER_NAME=
PRINT_TIMEOUT_MS=30000
PRINT_MAX_RETRIES=2
PRINT_JOB_RETENTION_HOURS=168

# Pakasir
PAKASIR_BASE_URL=https://app.pakasir.com
PAKASIR_PROJECT=
PAKASIR_API_KEY=
PAKASIR_METHOD=qris
